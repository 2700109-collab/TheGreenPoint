{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npx prisma generate --schema=packages/database/prisma/schema.prisma && cd apps/portal && npx vite build",
  "outputDirectory": "apps/portal/dist",
  "installCommand": "npm i -g pnpm && pnpm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/v1/(.*)", "destination": "/api/v1/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
