{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter @ncts/database exec prisma generate && pnpm --filter @ncts/portal exec vite build",
  "outputDirectory": "apps/portal/dist",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/v1/(.*)", "destination": "/api/v1/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
