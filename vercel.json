{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd packages/database && npx prisma generate && cd ../.. && pnpm --filter @ncts/portal exec vite build",
  "outputDirectory": "apps/portal/dist",
  "installCommand": "pnpm install",
  "framework": null,
  "functions": {
    "api/v1/[...path].ts": {
      "includeFiles": "packages/database/generated/**"
    }
  },
  "routes": [
    { "src": "/api/v1/(.*)", "dest": "/api/v1/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
