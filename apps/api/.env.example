# NCTS API Environment Variables
# Copy to .env and fill in values
# Get Neon connection strings from: https://console.neon.tech

# Server
PORT=3000
NODE_ENV=development

# Database (Neon serverless PostgreSQL)
# Pooled URL (PgBouncer) for runtime queries
DATABASE_URL=postgresql://USER:PASSWORD@ENDPOINT-pooler.REGION.aws.neon.tech/ncts_dev?sslmode=require
# Direct URL for migrations (bypasses PgBouncer)
DIRECT_URL=postgresql://USER:PASSWORD@ENDPOINT.REGION.aws.neon.tech/ncts_dev?sslmode=require

# Redis
REDIS_URL=redis://localhost:6379

# AWS Cognito
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=af-south-1

# AWS S3
S3_BUCKET=ncts-documents-dev
S3_REGION=af-south-1

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Audit
AUDIT_HASH_SECRET=change-me-in-production

# QR Code
QR_HMAC_SECRET=change-me-in-production
QR_BASE_URL=http://localhost:5175/verify

# JWT (for Section 1)
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
