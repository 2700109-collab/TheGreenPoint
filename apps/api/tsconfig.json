{
  "extends": "@ncts/tsconfig/nestjs.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "../..",
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "baseUrl": ".",
    "paths": {
      "@test/*": ["./test/*"],
      "@ncts/database": ["../../packages/database/src"],
      "@ncts/shared-types": ["../../packages/shared-types/src"],
      "@ncts/audit-lib": ["../../packages/audit-lib/src"]
    },
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src/**/*.ts", "test/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
