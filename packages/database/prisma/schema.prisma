  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  facility Facility @relation(fields: [facilityId], references: [id])

  @@index([tenantId, season])
  @@map("planting_intentions")
}

// 0.2.12 Consent Model (P2)
model Consent {
